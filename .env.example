# ─────────────────────────────────────────────
#  Copie ce fichier en « .env » et remplis les valeurs.
#  Le vrai .env n'est JAMAIS committé (voir .gitignore).
# ─────────────────────────────────────────────

# Clé secrète pour signer les tokens JWT.
# Génère-en une avec :  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Durée de validité d'un token de connexion, en minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Clé d'API The Movie Database (pour l'import des films).
TMDB_API_KEY=

# URL de connexion à la base.
# SQLite en local pour l'instant ; PostgreSQL plus tard.
DATABASE_URL=sqlite:///./cinema.db
